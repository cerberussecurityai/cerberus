# Cargo build artifacts
/target/
**/*.rs.bk

# Customer distribution bundle staged by `make bundle` (wasm + asset files +
# install.sh, tarball + SHA256SUMS). Reproduced from `make build` output and
# attached to GitHub Releases by CI — never committed.
/dist/
# NOTE: Cargo.lock IS committed for this crate (it produces a wasm
# artifact; Cargo.lock locks dependency versions for reproducible
# builds — same convention as binary crates).

# PDK-generated config — `src/generated/config.rs` is regenerated by
# `make build-asset-files` from definition/gcl.yaml. Committed so the
# crate compiles without first running the toolchain (matches the
# convention of `anypoint-cli-v4 pdk policy-project create` scaffolds).
# `src/generated/mod.rs` is hand-written and re-exports config.

# Parity-fixture symlink populated by `make sync-fixtures`
/tests/fixtures

# Local-mode Flex Gateway registration artifacts (generated by
# `flexctl registration create`). Tied to a specific Anypoint
# Connected App + environment — never commit.
/playground/config/registration.yaml
/playground/config/certificate.yaml

# Custom policy artifacts copied in by `make run`. Regenerated each
# build from target/wasm32-wasip1/release/.
/playground/config/custom-policies/*.yaml

# PDK CLI scratch dir
.pdk/

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store
